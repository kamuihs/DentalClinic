{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2017",
    "strict": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "rootDir": "src",       // pasta raiz do código
    "outDir": "dist",       // pasta de saída dos compilados
    "baseUrl": ".",         // raiz do projeto
    "ignoreDeprecations": "6.0", // silencia aviso sobre baseUrl deprecado
    "types": ["node"],      // adiciona suporte ao Node
    "paths": {
      "*": ["node_modules/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
